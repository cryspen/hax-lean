def num.I8.checked_div
  (x : Std.I8) (y : Std.I8) : Result (option.Option Std.I8) := do
  if y = 0#i8
  then ok option.Option.None
  else
    if x = num.I8.MIN
    then
      if y = (-1)#i8
      then ok option.Option.None
      else let i ← x / y
           ok (option.Option.Some i)
